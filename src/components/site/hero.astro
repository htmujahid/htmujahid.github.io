---
import { buttonVariants } from "@/components/ui/button"
import { Badge } from "@/components/ui/badge"
import { profile } from "@/data/profile"
---

<section
  id="home"
  class="hero-bg relative flex min-h-[calc(100svh-4rem)] w-full scroll-mt-16 flex-col items-center justify-center gap-6 overflow-hidden px-6 pt-12 pb-28 text-center"
>
  <div class="hero-grid pointer-events-none absolute inset-0 -z-20" aria-hidden="true"></div>

  <svg
    class="pointer-events-none absolute inset-0 -z-10 h-full w-full text-foreground"
    viewBox="0 0 1440 800"
    preserveAspectRatio="xMidYMid slice"
    fill="none"
    aria-hidden="true"
  >
    <g fill="currentColor" class="opacity-[0.14]">
      <circle cx="90" cy="110" r="4"></circle>
      <circle cx="250" cy="210" r="3"></circle>
      <circle cx="190" cy="380" r="4"></circle>
      <circle cx="70" cy="470" r="3"></circle>
      <circle cx="250" cy="640" r="3.5"></circle>
      <circle cx="420" cy="120" r="3"></circle>

      <circle cx="1350" cy="130" r="4"></circle>
      <circle cx="1200" cy="230" r="3"></circle>
      <circle cx="1260" cy="400" r="4"></circle>
      <circle cx="1370" cy="500" r="3"></circle>
      <circle cx="1190" cy="650" r="3.5"></circle>
      <circle cx="1030" cy="150" r="3"></circle>
    </g>

    <g
      stroke="currentColor"
      stroke-width="1.25"
      class="opacity-[0.12]"
      transform="translate(120 560) rotate(-8)"
    >
      <rect x="0" y="0" width="110" height="62" rx="8"></rect>
      <line x1="16" y1="20" x2="62" y2="20" stroke-width="2.5" stroke-linecap="round"></line>
      <line x1="16" y1="32" x2="86" y2="32" stroke-width="2.5" stroke-linecap="round"></line>
      <line x1="16" y1="44" x2="48" y2="44" stroke-width="2.5" stroke-linecap="round"></line>
    </g>

    <g
      stroke="currentColor"
      stroke-width="1.25"
      class="opacity-[0.12]"
      transform="translate(1240 100) rotate(7)"
    >
      <rect x="0" y="0" width="118" height="66" rx="8"></rect>
      <line x1="16" y1="21" x2="68" y2="21" stroke-width="2.5" stroke-linecap="round"></line>
      <line x1="16" y1="34" x2="92" y2="34" stroke-width="2.5" stroke-linecap="round"></line>
      <line x1="16" y1="47" x2="54" y2="47" stroke-width="2.5" stroke-linecap="round"></line>
    </g>
  </svg>

  <div
    class="pointer-events-none absolute top-[44%] left-1/2 -z-10 size-[42rem] -translate-x-1/2 -translate-y-1/2 rounded-full bg-foreground/[0.06] blur-3xl"
    aria-hidden="true"
  >
  </div>

  <div class="flex w-full max-w-3xl flex-col items-center gap-6">
    {
      profile.availableForWork && (
        <Badge
          variant="outline"
          className="w-fit border border-border px-2.5 py-1"
        >
          <span class="mr-1.5 inline-block size-1.5 rounded-full bg-emerald-500" />
          Available for work
        </Badge>
      )
    }

    <div class="flex flex-col gap-3">
      <h1 class="text-4xl leading-tight font-bold tracking-tight sm:text-6xl">
        {profile.name}
      </h1>
      <p
        class="text-lg font-semibold tracking-wide text-muted-foreground uppercase sm:text-xl"
      >
        {profile.role}
      </p>
    </div>

    <p class="max-w-2xl text-base leading-relaxed text-muted-foreground">
      {profile.bio}
    </p>

    <div class="flex flex-wrap items-center justify-center gap-3 pt-2">
      <a href="#projects" class={buttonVariants({ size: "lg" })}>
        View Projects
      </a>
      <a
        href="#contact"
        class={buttonVariants({ size: "lg", variant: "outline" })}
      >
        Get In Touch
      </a>
    </div>
  </div>
</section>

<style>
  .hero-grid {
    background-image:
      linear-gradient(to right, var(--color-border) 1px, transparent 1px),
      linear-gradient(to bottom, var(--color-border) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(
      ellipse 60% 55% at 50% 44%,
      black 0%,
      transparent 75%
    );
    opacity: 0.6;
  }
</style>
