---
interface Props {
  index: string
  title: string
  description?: string
}

const { index, title, description } = Astro.props
---

<div class="mb-12 flex flex-col gap-3">
  <div class="flex items-center gap-3 text-xs font-semibold tracking-widest text-muted-foreground uppercase">
    <span class="text-foreground">{index}</span>
    <span class="h-px w-8 bg-border"></span>
    <span>Section</span>
  </div>
  <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">{title}</h2>
  {description && <p class="max-w-2xl text-muted-foreground">{description}</p>}
</div>
